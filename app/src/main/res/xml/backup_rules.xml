<?xml version="1.0" encoding="utf-8"?>
<!--
   Auto Backup rules for devices below API 31.
   See https://developer.android.com/guide/topics/data/autobackup

   DataStore preferences (user progress/settings) back up by default; the regenerable
   Room database is excluded to avoid restoring a corrupt SQLite/WAL snapshot.
-->
<full-backup-content>
    <exclude domain="database" path="pmp.db" />
    <exclude domain="database" path="pmp.db-wal" />
    <exclude domain="database" path="pmp.db-shm" />
</full-backup-content>
